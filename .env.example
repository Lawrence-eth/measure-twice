# Server-side only. Never prefix this variable with NEXT_PUBLIC_.
OPENAI_API_KEY=

# gpt-5.6 is the hackathon-required flagship alias.
OPENAI_MODEL=gpt-5.6

# Set true for a deterministic, key-free judging/demo experience.
DEMO_MODE=true

# Optional extra salt for privacy-preserving GPT-5.6 safety identifiers.
SAFETY_SALT=replace-with-a-random-server-secret
