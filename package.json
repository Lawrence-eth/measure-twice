{
  "name": "pentimento",
  "version": "0.1.0",
  "private": true,
  "description": "An interactive education experience that guides complete beginners from an AI-build idea to a checked live link.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "vinext build",
    "build:next": "next build",
    "start": "wrangler dev --config dist/server/wrangler.json",
    "start:next": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build:vinext": "npm run build",
    "start:vinext": "wrangler dev --config dist/server/wrangler.json",
    "deploy:vinext": "vinext-cloudflare deploy --config dist/server/wrangler.json"
  },
  "dependencies": {
    "@fontsource-variable/instrument-sans": "^5.3.0",
    "@vinext/cloudflare": "1.0.0-beta.2",
    "next": "16.2.10",
    "openai": "6.48.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@cloudflare/vite-plugin": "1.45.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.28",
    "react-server-dom-webpack": "19.2.7",
    "typescript": "5.9.3",
    "vinext": "1.0.0-beta.2",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    }
  },
  "type": "module"
}
